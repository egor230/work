{
  "manifest_version": 3,
  "name": "take a screenshot",
  "version": "1.0",
  "description": "take a screenshot текущей вкладки",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting","tabs", "windows", "storage", "clipboardWrite",
        "downloads"],
  "content_scripts": [{
    "matches": ["https://www.youtube.com/watch *"],
    "js": ["popup.js"],
    "run_at": "document_end"
  }]
}
